# ═══════════════════════════════════════════════════════════════════════════════
# AI Lab Template — STAGING environment
# cp .env.staging.example .env.staging
# Then: docker compose --env-file .env.staging -f docker-compose.yml -f docker-compose.staging.yml up -d
#
# CHANGE every value marked [CHANGE]
# Values NOT marked [CHANGE] are usually fine to keep
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ailab_stg
APP_NAME=AI Lab (Staging)
NODE_ENV=staging

# ── Public URLs  ← THE MOST IMPORTANT ONES TO CHANGE ─────────────────────────
# These are the URLs visible from outside (browser, Telegram, other services)
# [CHANGE]
BACKEND_PUBLIC_URL=https://api.stg.yourdomain.com
# [CHANGE]
FRONTEND_PUBLIC_URL=https://stg.yourdomain.com
# [CHANGE] must end with /
N8N_WEBHOOK_URL=https://n8n.stg.yourdomain.com/

# ── Ports (behind reverse proxy, don't need to be exposed) ───────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
N8N_PORT=5678
# set to 0 or remove to not expose externally
DB_PORT=5432
# set to 0 or remove to not expose externally
REDIS_PORT=6379

# ── Database  [CHANGE passwords] ─────────────────────────────────────────────
DB_USER=ailab_stg
# [CHANGE]
DB_PASSWORD=CHANGE_ME_strong_password_stg
DB_NAME=ailab_stg
N8N_DB_NAME=n8n_stg

# ── Redis ─────────────────────────────────────────────────────────────────────
# [CHANGE]
REDIS_PASSWORD=CHANGE_ME_redis_password_stg

# ── Auth  [CHANGE ALL] ────────────────────────────────────────────────────────
# [CHANGE]
JWT_SECRET=CHANGE_ME_min_32_chars_random_stg_secret
JWT_EXPIRES_IN=7d
# [CHANGE]
SUPERADMIN_EMAIL=superadmin@yourdomain.com
# [CHANGE]
SUPERADMIN_PASSWORD=CHANGE_ME_superadmin_password

# ── n8n  [CHANGE secrets] ─────────────────────────────────────────────────────
N8N_USER=admin
# [CHANGE]
N8N_PASSWORD=CHANGE_ME_n8n_password_stg
# [CHANGE] keep stable
N8N_ENCRYPTION_KEY=CHANGE_ME_32_chars_min_stg_encryption_key
# [CHANGE]
N8N_WEBHOOK_SECRET=CHANGE_ME_webhook_secret_stg
# fill after first n8n startup
N8N_API_KEY=
N8N_LOG_LEVEL=info

# ── AI Providers — same keys as dev, or separate stg keys ────────────────────
# [CHANGE]
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_PRIORITY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# [CHANGE] use a separate stg bot
TELEGRAM_BOT_TOKEN=
# [CHANGE]
TELEGRAM_BOT_USERNAME=

# ── Misc ──────────────────────────────────────────────────────────────────────
TIMEZONE=America/Mexico_City
# [CHANGE]
CORS_ORIGINS=https://stg.yourdomain.com
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# [CHANGE]
NEXT_PUBLIC_API_URL=https://stg.yourdomain.com/api

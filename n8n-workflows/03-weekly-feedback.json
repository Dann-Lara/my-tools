{
  "name": "03 - Weekly AI Feedback (Sunday 20:00)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 20 * * 0"
            }
          ]
        }
      },
      "id": "weekly-trigger",
      "name": "Every Sunday 20:00",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        240,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_PUBLIC_URL }}/v1/checklists/active-with-telegram",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 15000
        }
      },
      "id": "get-all-checklists",
      "name": "Get Active Checklists (n8n)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        460,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "EfBrBbQ88fwJlS4R",
          "name": "Header Auth account"
        }
      },
      "notes": "Uses x-webhook-secret. Returns only active checklists with telegramChatId."
    },
    {
      "parameters": {
        "jsCode": "// Input is already filtered by the backend endpoint\n// Just ensure items are properly mapped\nconst items = Array.isArray($input.item.json) ? $input.item.json : [$input.item.json];\nreturn items.filter(c => c && c.id && c.telegramChatId).map(c => ({ json: c }));"
      },
      "id": "filter-active",
      "name": "Validate Items",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        680,
        300
      ]
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_PUBLIC_URL }}/v1/checklists/{{ $json.id }}/feedback",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "options": {
          "timeout": 45000
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{}"
      },
      "id": "generate-feedback",
      "name": "Generate AI Feedback",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "EfBrBbQ88fwJlS4R",
          "name": "Header Auth account"
        }
      }
    },
    {
      "parameters": {
        "chatId": "={{ $('Filter Active + Has Telegram').item.json.telegramChatId }}",
        "text": "🤖 *Feedback semanal — {{ $('Validate Items').item.json.title }}*\n\n{{ $json.feedbackText }}\n\n_Generado por AI Lab · Semana {{ $json.weekNumber }}_",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "send-feedback-telegram",
      "name": "Send Feedback via Telegram",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [
        1120,
        300
      ],
      "credentials": {
        "telegramApi": {
          "id": "8JyddEiApG6k1J3x",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "url": "={{ $env.BACKEND_PUBLIC_URL }}/v1/webhooks/n8n",
        "method": "POST",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ type: 'weekly-feedback-complete', count: $('Filter Active + Has Telegram').all().length, timestamp: new Date().toISOString() }) }}",
        "options": {}
      },
      "id": "notify-backend",
      "name": "Notify Backend (log)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1340,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "EfBrBbQ88fwJlS4R",
          "name": "Header Auth account"
        }
      }
    }
  ],
  "connections": {
    "Every Sunday 20:00": {
      "main": [
        [
          {
            "node": "Get Active Checklists (n8n)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Validate Items": {
      "main": [
        [
          {
            "node": "Generate AI Feedback",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Generate AI Feedback": {
      "main": [
        [
          {
            "node": "Send Feedback via Telegram",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Send Feedback via Telegram": {
      "main": [
        [
          {
            "node": "Notify Backend (log)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Active Checklists (n8n)": {
      "main": [
        [
          {
            "node": "Validate Items",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "errorWorkflow": ""
  },
  "tags": [
    "checklist",
    "feedback",
    "weekly",
    "telegram"
  ],
  "meta": {
    "description": "Every Sunday at 20:00 generates AI feedback for each active checklist and sends it via Telegram. Requires: Telegram Bot + Backend Webhook Secret with a superadmin Bearer token."
  }
}
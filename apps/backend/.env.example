# ═══════════════════════════════════════════════════════════════════════════════
# Backend — apps/backend/.env
# Used ONLY when running the backend locally without Docker (npm run dev).
# When running via Docker Compose, all vars come from the ROOT .env file.
#
# Copy: cp apps/backend/.env.example apps/backend/.env
# Then fill in your real values below.
# ═══════════════════════════════════════════════════════════════════════════════

PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── Database (localhost because you're NOT inside Docker network) ─────────────
DATABASE_URL=postgresql://admin:secret@localhost:5432/ailab
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
SUPERADMIN_EMAIL=superadmin@ailab.dev
SUPERADMIN_PASSWORD=SuperAdmin123!

# ── AI Providers ──────────────────────────────────────────────────────────────
# Set at least ONE key. Leave the rest empty.
# Get a free Gemini key: https://aistudio.google.com/app/apikey
# Get a free Groq key:   https://console.groq.com

GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Optional: override provider order (comma-separated)
AI_PROVIDER_PRIORITY=

# ── n8n (localhost because you're NOT inside Docker network) ──────────────────
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=change-me
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhZDBjY2Y1Ni1hMTgzLTQwOWYtYTk2ZS0yOTg2Yjk2YWU5YTUiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwiaWF0IjoxNzcyNDE4OTA3fQ.WRFapO8NwHcykmiMvbMdhxKlp2JK-U453aIUFFuTdBs
N8N_USER=dkubdannspc@gmail.com
N8N_PASSWORD=n8nDann!2025

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=AiLabDannBot

# ── Public URL ────────────────────────────────────────────────────────────────
BACKEND_PUBLIC_URL=http://host.docker.internal:3001

# ── Throttling ────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

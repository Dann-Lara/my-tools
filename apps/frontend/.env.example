# ═══════════════════════════════════════════════════════════════════════════════
# Frontend — apps/frontend/.env.local
# Used when running Next.js LOCALLY (npm run dev, not inside Docker).
# Copy to: apps/frontend/.env.local
#
# When running via Docker Compose, vars come from the ROOT .env file.
# ═══════════════════════════════════════════════════════════════════════════════

# API base URL (server-side proxy routes forward here)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Telegram bot username shown in the "How to get Chat ID" modal (no @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername

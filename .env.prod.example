# ═══════════════════════════════════════════════════════════════════════════════
# AI Lab Template — PRODUCTION environment
# cp .env.prod.example .env.prod
# Then: docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# ⚠️  NEVER commit .env.prod to git.
# ⚠️  Use a secrets manager (Vault, AWS SSM, Doppler) for production.
# CHANGE every value — use strong random secrets.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=ailab_prod
APP_NAME=AI Lab
NODE_ENV=production

# ── Public URLs  ← THE MOST IMPORTANT ONES TO CHANGE ─────────────────────────
# [CHANGE]
BACKEND_PUBLIC_URL=https://api.yourdomain.com
# [CHANGE]
FRONTEND_PUBLIC_URL=https://yourdomain.com
# [CHANGE] must end with /
N8N_WEBHOOK_URL=https://n8n.yourdomain.com/

# ── Ports ─────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
N8N_PORT=5678
# In prod, DB/Redis should NOT be exposed — managed by docker-compose.prod.yml
DB_PORT=5432
REDIS_PORT=6379

# ── Database  [CHANGE ALL] ────────────────────────────────────────────────────
DB_USER=ailab_prod
# [CHANGE] min 20 chars random
DB_PASSWORD=CHANGE_ME_strong_prod_db_password
DB_NAME=ailab_prod
N8N_DB_NAME=n8n_prod

# ── Redis  [CHANGE] ───────────────────────────────────────────────────────────
# [CHANGE]
REDIS_PASSWORD=CHANGE_ME_strong_redis_password

# ── Auth  [CHANGE ALL — use openssl rand -base64 32] ─────────────────────────
# [CHANGE]
JWT_SECRET=CHANGE_ME_min_32_chars_random_production_secret
# shorter expiry in production
JWT_EXPIRES_IN=1d
# [CHANGE]
SUPERADMIN_EMAIL=admin@yourdomain.com
# [CHANGE]
SUPERADMIN_PASSWORD=CHANGE_ME_very_strong_password

# ── n8n  [CHANGE ALL] ─────────────────────────────────────────────────────────
N8N_USER=admin
# [CHANGE]
N8N_PASSWORD=CHANGE_ME_n8n_prod_password
# [CHANGE] NEVER change after first run
N8N_ENCRYPTION_KEY=CHANGE_ME_32_chars_random_prod
# [CHANGE]
N8N_WEBHOOK_SECRET=CHANGE_ME_random_webhook_secret
# fill after first n8n startup
N8N_API_KEY=
# warn in prod to reduce noise
N8N_LOG_LEVEL=warn

# ── AI Providers ──────────────────────────────────────────────────────────────
# [CHANGE]
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.0-flash
GROQ_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER_PRIORITY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# [CHANGE]
TELEGRAM_BOT_TOKEN=
# [CHANGE]
TELEGRAM_BOT_USERNAME=

# ── Misc ──────────────────────────────────────────────────────────────────────
TIMEZONE=America/Mexico_City
# [CHANGE] comma-separated if multiple
CORS_ORIGINS=https://yourdomain.com
THROTTLE_TTL=60000
# stricter in prod
THROTTLE_LIMIT=50
# [CHANGE]
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

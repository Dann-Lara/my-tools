{
  "name": "New User Welcome Email",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "new-user",
        "authentication": "headerAuth",
        "options": {}
      },
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://backend:3001/v1/ai/generate",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "prompt",
              "value": "=Generate a friendly welcome email for {{ $json.name }} who joined our AI Lab platform."
            },
            { "name": "systemMessage", "value": "You are a friendly onboarding assistant. Keep emails under 100 words." }
          ]
        }
      },
      "name": "Generate Welcome Email",
      "type": "n8n-nodes-base.httpRequest",
      "position": [460, 300]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={ \"emailContent\": {{ $json.result }}, \"userId\": {{ $('Webhook Trigger').item.json.userId }} }"
      },
      "name": "Respond to Backend",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [680, 300]
    }
  ],
  "connections": {
    "Webhook Trigger": { "main": [[{ "node": "Generate Welcome Email", "type": "main", "index": 0 }]] },
    "Generate Welcome Email": { "main": [[{ "node": "Respond to Backend", "type": "main", "index": 0 }]] }
  }
}

# ═══════════════════════════════════════════════════════════════════════════════
# AI Lab Template — Root environment file
#
# This file is read by Docker Compose for ALL services.
# Copy to the right file depending on your environment:
#
#   Local dev:  cp .env.example .env
#   Staging:    cp .env.example .env.staging   → change URLS + secrets
#   Production: cp .env.example .env.prod      → change URLS + ALL secrets
#
# ┌─────────────────────────────────────────────────────────────────────────┐
# │  Variables that CHANGE between environments are marked with [CHANGE]    │
# │  Variables that can stay the same are marked with [OK in dev]           │
# └─────────────────────────────────────────────────────────────────────────┘
# ═══════════════════════════════════════════════════════════════════════════════

# ── Project ───────────────────────────────────────────────────────────────────
# [OK in dev] Changes container names prefix
COMPOSE_PROJECT_NAME=ailab
APP_NAME=AI Lab
# [CHANGE] → staging | production
NODE_ENV=development

# ── Public URLs  [CHANGE per environment] ────────────────────────────────────
# These are the URLs visible from the OUTSIDE (browser, Telegram, other services)
# Dev:  http://localhost:XXXX
# Stg:  https://stg.yourdomain.com
# Prod: https://yourdomain.com

BACKEND_PUBLIC_URL=http://host.docker.internal:3001
FRONTEND_PUBLIC_URL=http://localhost:3000
# Must end with /
N8N_WEBHOOK_URL=http://localhost:5678/

# ── Ports  [OK in dev, may need to change in stg/prod if behind proxy] ────────
FRONTEND_PORT=3000
BACKEND_PORT=3001
N8N_PORT=5678
DB_PORT=5432
REDIS_PORT=6379

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=admin
# [CHANGE in stg/prod] Use a strong password
DB_PASSWORD=secret
DB_NAME=ailab
N8N_DB_NAME=n8n
# Full connection URL — used by backend for local dev (not inside Docker)
DATABASE_URL=postgresql://admin:secret@localhost:5432/ailab
REDIS_URL=redis://localhost:6379

# ── Redis  [CHANGE password in prod] ─────────────────────────────────────────
# Leave empty in dev; set in prod
REDIS_PASSWORD=

# ── Auth — CHANGE ALL IN STG/PROD ────────────────────────────────────────────
JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=7d
SUPERADMIN_EMAIL=superadmin@ailab.dev
# [CHANGE in stg/prod]
SUPERADMIN_PASSWORD=SuperAdmin123!

# ── n8n ───────────────────────────────────────────────────────────────────────
N8N_USER=dkubdannspc@gmail.com
# [CHANGE in stg/prod]
N8N_PASSWORD=n8nDann!2025
# [CHANGE] keep same across restarts
N8N_ENCRYPTION_KEY=change-me-32-chars-minimum-here!!
# [CHANGE] shared secret backend↔n8n
N8N_WEBHOOK_SECRET=change-me

# n8n API Key — created in n8n UI: Settings → n8n API → Create API Key
# Used by `npm run n8n:sync` to push workflows automatically
# Leave empty to use basic auth fallback (N8N_USER / N8N_PASSWORD)
N8N_API_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJzdWIiOiJhZDBjY2Y1Ni1hMTgzLTQwOWYtYTk2ZS0yOTg2Yjk2YWU5YTUiLCJpc3MiOiJuOG4iLCJhdWQiOiJwdWJsaWMtYXBpIiwiaWF0IjoxNzcyNDE4OTA3fQ.WRFapO8NwHcykmiMvbMdhxKlp2JK-U453aIUFFuTdBs

# ── AI Providers — set ONE or more ───────────────────────────────────────────
# Priority order (default): gemini → groq → openai → deepseek → anthropic
# Override: AI_PROVIDER_PRIORITY=openai,gemini

# https://aistudio.google.com/app/apikey  (free tier)
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# https://console.groq.com  (free tier, fast)
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# https://platform.deepseek.com  (cheap)
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-3-haiku-20240307

# Optional: gemini,groq,openai (comma-separated)
AI_PROVIDER_PRIORITY=

# ── Telegram  [CHANGE] ────────────────────────────────────────────────────────
# Create bot: open Telegram → @BotFather → /newbot
TELEGRAM_BOT_TOKEN=
# Without @, e.g. MyAiLabBot
TELEGRAM_BOT_USERNAME=AiLabDannBot

# ── Misc ──────────────────────────────────────────────────────────────────────
TIMEZONE=America/Mexico_City
# [CHANGE] → https://yourdomain.com in prod
CORS_ORIGINS=http://localhost:3000
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
# debug | info | warn | error
N8N_LOG_LEVEL=info

# ── Frontend public vars (read by Next.js) ────────────────────────────────────
# [CHANGE] → https://yourdomain.com/api
NEXT_PUBLIC_API_URL=http://localhost:3000/api
